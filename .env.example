# VeresVill CRM - Környezeti változók
# Másolja .env néven és töltse ki az értékeket!

# Adatbázis
DB_HOST=localhost
DB_NAME=veresvill_crm
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Email küldés módja: phpmail (szerver mail) vagy smtp
MAIL_METHOD=phpmail

# SMTP Email (csak ha MAIL_METHOD=smtp)
SMTP_HOST=mail.veresvill.hu
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=ajanlatkeres@veresvill.hu
SMTP_PASS=
ADMIN_EMAIL=veresvill.ads@gmail.com
ADMIN_NAME=Veresvill
FROM_EMAIL=ajanlatkeres@veresvill.hu
FROM_NAME=Veresvill - Villamos Felülvizsgálat

# reCAPTCHA
RECAPTCHA_SECRET=

# VAPID Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:veresvill.ads@gmail.com

# Google Calendar API (szinkronhoz)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
APP_URL=https://veresvill.hu
APP_ENV=production
APP_DEBUG=false
APP_BASE_PATH=
